{
	"name": "hello-sandbox-demo",
	"version": "1.0.0",
	"type": "module",
	"private": true,
	"description": "Cloudflare Sandbox SDK interactive demo",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite build && vite preview",
		"deploy": "vite build && wrangler deploy",
		"cf-typegen": "wrangler types",
		"typecheck": "tsc -b",
		"lint": "prettier --check . && eslint --cache --format=stylish .",
		"format": "prettier --write . && eslint --cache --format=stylish --fix .",
		"knip": "knip --production",
		"prepare": "husky"
	},
	"dependencies": {
		"@opencode-ai/sdk": "^1.2.26",
		"ai": "^6",
		"hono": "^4",
		"lucide-react": "^0.577.0",
		"motion": "^12.36.0",
		"react": "^19",
		"react-dom": "^19",
		"sugar-high": "^0.9.5",
		"workers-ai-provider": "^3",
		"zod": "^4"
	},
	"devDependencies": {
		"@cloudflare/sandbox": "^0.7.17",
		"@cloudflare/vite-plugin": "^1",
		"@eslint/js": "^10.0.1",
		"@tailwindcss/vite": "^4",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@vitejs/plugin-react": "^4",
		"@xterm/addon-fit": "^0.11",
		"@xterm/xterm": "^6",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-better-tailwindcss": "^4.3.2",
		"eslint-plugin-import-x": "^4.16.2",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"eslint-plugin-unicorn": "^63.0.0",
		"eslint-plugin-unused-imports": "^4.4.1",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"knip": "^5.86.0",
		"lint-staged": "^16.4.0",
		"prettier": "^3.8.1",
		"tailwindcss": "^4",
		"typescript": "^5",
		"typescript-eslint": "^8.57.0",
		"vite": "^7",
		"wrangler": "^4"
	}
