{
	"compilerOptions": {
		"target": "esnext",
		"lib": ["esnext", "DOM", "DOM.Iterable"],
		"module": "esnext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"paths": {
			"@/*": ["./src/client/*"]
		}
	},
	"include": ["src/client/**/*.ts", "src/client/**/*.tsx"]
}
