{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Attach to Dev Server (Worker)",
			"type": "node",
			"request": "attach",
			"port": 9229,
			"restart": true,
			"localRoot": "${workspaceFolder}",
			"remoteRoot": "${workspaceFolder}",
			"skipFiles": ["<node_internals>/**"]
		},
		{
			"name": "Attach to Worker (WebSocket)",
			"type": "node",
			"request": "attach",
			"websocketAddress": "ws://localhost:9229/hello-sandbox",
			"resolveSourceMapLocations": null,
			"attachExistingChildren": false,
			"autoAttachChildProcesses": false,
			"sourceMaps": true
		},
		{
			"name": "Debug in Chrome (Client)",
			"type": "chrome",
			"request": "launch",
			"url": "http://localhost:5173",
			"webRoot": "${workspaceFolder}/src",
			"sourceMaps": true
		}
	],
	"compounds": [
		{
			"name": "Full Stack Debug",
			"configurations": ["Attach to Worker (WebSocket)", "Debug in Chrome (Client)"],
			"stopAll": true
		}
	]
}
