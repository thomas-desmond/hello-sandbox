{
	"compilerOptions": {
		"target": "esnext",
		"lib": ["esnext"],
		"module": "esnext",
		"moduleResolution": "bundler",
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"types": ["./worker-configuration.d.ts"]
	},
	"include": ["src/index.ts", "src/api/**/*.ts", "worker-configuration.d.ts"]
}
